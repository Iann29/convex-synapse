#!/usr/bin/env python3
"""
synapse-updater — tiny HTTP daemon that runs setup.sh --upgrade on demand.

Listens on a unix domain socket at /run/synapse/updater.sock. The synapse-api
container reaches it via a bind-mount of the same path. Unix sockets sidestep
the TCP-binding dilemma (127.0.0.1 isn't reachable from container userspace;
0.0.0.0 exposes the daemon to the public internet) and let kernel-level
DAC handle access control via socket permissions.

Why a host process (not a docker compose service):
  setup.sh --upgrade runs `docker compose up -d --build`, which would
  recreate the updater itself if it lived in compose — killing the very
  process orchestrating the upgrade. Living on the host as a systemd unit
  means the updater survives the upgrade and can keep updating its
  status file while every container around it is being recycled.

Endpoints:
  GET  /healthz              → 200 {"ok": true}
  GET  /version              → 200 {"version": "1.0.3"}    (reads VERSION file or git)
  GET  /status               → 200 status JSON              (idle | running | success | failed)
  POST /upgrade {ref?: str}  → 202 {"started": true}
                               409 if upgrade already in progress
  POST /reconfigure_host_domain {jobId, domain?, baseDomain?, plainHttp?, acmeEmail?}
                             → 202 {"started": true, "jobId": "<id>"}
                               409 if a reconfigure is already in progress
                               (writes back to the admin_jobs row via psql)

State files (persisted across daemon restarts):
  /var/lib/synapse-updater/status.json     — last known upgrade state
  /var/lib/synapse-updater/upgrade.lock    — present while an upgrade child is running
  /var/lib/synapse-updater/reconfigure.lock — present while a reconfigure child is running
  /var/log/synapse-updater/<utc>.log       — full log of the last/current upgrade
  /var/log/synapse-updater/reconfigure-<utc>.log — full log of the last/current reconfigure

Run as root (User=root in the systemd unit) — setup.sh writes to /opt/synapse,
talks to /var/run/docker.sock, and may call apt-get; sub-rooting that to a
dedicated user buys ~nothing on a single-tenant VPS.
"""

import json
import os
import shlex
import shutil
import socketserver
import subprocess
import sys
import threading
import time
from datetime import datetime, timezone
from http.server import BaseHTTPRequestHandler
from pathlib import Path

SOCKET_PATH = Path(os.environ.get("SYNAPSE_UPDATER_SOCKET", "/run/synapse/updater.sock"))
INSTALL_DIR = Path(os.environ.get("SYNAPSE_INSTALL_DIR", "/opt/synapse"))
STATE_DIR = Path(os.environ.get("SYNAPSE_UPDATER_STATE_DIR", "/var/lib/synapse-updater"))
LOG_DIR = Path(os.environ.get("SYNAPSE_UPDATER_LOG_DIR", "/var/log/synapse-updater"))
LOG_TAIL_LINES = 200

STATE_DIR.mkdir(parents=True, exist_ok=True)
LOG_DIR.mkdir(parents=True, exist_ok=True)
SOCKET_PATH.parent.mkdir(parents=True, exist_ok=True)

STATUS_FILE = STATE_DIR / "status.json"
LOCK_FILE = STATE_DIR / "upgrade.lock"
RECONFIGURE_LOCK_FILE = STATE_DIR / "reconfigure.lock"

upgrade_lock = threading.Lock()
reconfigure_lock = threading.Lock()


def utc_now() -> str:
    return datetime.now(timezone.utc).isoformat()


def write_status(state: dict) -> None:
    """Atomic write — readers never see a half-written file."""
    tmp = STATUS_FILE.with_suffix(".tmp")
    tmp.write_text(json.dumps(state))
    tmp.replace(STATUS_FILE)


def read_status() -> dict:
    if not STATUS_FILE.exists():
        return {"state": "idle"}
    try:
        return json.loads(STATUS_FILE.read_text())
    except (json.JSONDecodeError, OSError):
        return {"state": "idle"}


def read_version() -> str:
    """Best-effort current-version detection. VERSION file wins (written by
    setup.sh on each install/upgrade); falls back to `git describe` from the
    install dir; finally returns 'unknown'."""
    vfile = INSTALL_DIR / "VERSION"
    if vfile.exists():
        try:
            v = vfile.read_text().strip()
            if v:
                return v
        except OSError:
            pass
    git = shutil.which("git")
    if git and (INSTALL_DIR / ".git").exists():
        try:
            out = subprocess.run(
                [git, "-C", str(INSTALL_DIR), "describe", "--tags", "--always"],
                capture_output=True, text=True, timeout=5, check=False,
            )
            if out.returncode == 0 and out.stdout.strip():
                return out.stdout.strip().lstrip("v")
        except (subprocess.SubprocessError, OSError):
            pass
    return "unknown"


def tail_log(path: Path, n: int = LOG_TAIL_LINES) -> list[str]:
    if not path.exists():
        return []
    try:
        # Read the whole file — these logs are small (a single setup.sh run
        # is ~few hundred lines max). Splitlines + tail is simpler than a
        # seek-based reverse read and the size cap means it stays cheap.
        lines = path.read_text(errors="replace").splitlines()
        return lines[-n:]
    except OSError:
        return []


def run_upgrade(ref: str) -> None:
    """Worker thread: runs setup.sh --upgrade and updates status as it goes."""
    started_at = utc_now()
    log_path = LOG_DIR / f"{datetime.now(timezone.utc).strftime('%Y%m%dT%H%M%SZ')}.log"

    write_status({
        "state": "running",
        "ref": ref,
        "startedAt": started_at,
        "logPath": str(log_path),
    })

    cmd = [str(INSTALL_DIR / "setup.sh"), "--upgrade", "--non-interactive"]
    if ref:
        cmd.append(f"--ref={ref}")

    # Inheriting our environment but setting a sentinel so
    # phase_install_updater inside setup.sh doesn't `systemctl restart
    # synapse-updater` and kill us mid-upgrade. Operator restarts the
    # daemon manually after a successful upgrade to pick up daemon-
    # binary changes (rare; this Python is small and stable).
    child_env = dict(os.environ)
    child_env["SYNAPSE_UPDATER_NO_RESTART"] = "1"

    exit_code = 1
    try:
        with open(log_path, "wb") as logf:
            logf.write(f"[synapse-updater] starting: {' '.join(shlex.quote(c) for c in cmd)}\n".encode())
            logf.flush()
            proc = subprocess.Popen(
                cmd,
                stdout=logf,
                stderr=subprocess.STDOUT,
                cwd=str(INSTALL_DIR),
                env=child_env,
            )
            exit_code = proc.wait()
    except (OSError, subprocess.SubprocessError) as e:
        # setup.sh missing, permission denied, fork failure, etc.
        try:
            with open(log_path, "ab") as logf:
                logf.write(f"\n[synapse-updater] spawn error: {e}\n".encode())
        except OSError:
            pass
        exit_code = 1

    finished_at = utc_now()
    final_state = "success" if exit_code == 0 else "failed"

    write_status({
        "state": final_state,
        "ref": ref,
        "startedAt": started_at,
        "finishedAt": finished_at,
        "exitCode": exit_code,
        "logPath": str(log_path),
        "logTail": tail_log(log_path),
    })

    try:
        LOCK_FILE.unlink()
    except FileNotFoundError:
        pass


# ---------- reconfigure_host_domain ----------
#
# A second job kind that drives `setup.sh --reconfigure ...`. Unlike
# /upgrade, the daemon updates an admin_jobs row in Postgres so the
# Synapse api can render progress to the operator without the daemon
# needing to expose a per-job /status route. Lock file keeps two
# reconfigures from racing the same compose stack.

def _resolve_env_var(key: str) -> str:
    """Read a single KEY=value line out of $INSTALL_DIR/.env. We re-read
    the file each call so an operator who edits .env between calls sees
    the new value. Returns "" if no .env / no key — caller treats that
    as "skip" (the api will see state='queued' until something flips it
    manually)."""
    env_path = INSTALL_DIR / ".env"
    if not env_path.exists():
        return ""
    try:
        prefix = key + "="
        for line in env_path.read_text().splitlines():
            line = line.strip()
            if not line or line.startswith("#"):
                continue
            if line.startswith(prefix):
                return line[len(prefix):].strip().strip('"').strip("'")
    except OSError:
        return ""
    return ""


def _resolve_postgres_dsn() -> str:
    """Resolve the metadata-DB DSN the api server uses. Reads the
    canonical SYNAPSE_DB_URL key (written by env.tmpl since v0.6) with a
    POSTGRES_URL fallback for any operator who customized the env (and
    backward compat for early dev installs that used POSTGRES_URL)."""
    return _resolve_env_var("SYNAPSE_DB_URL") or _resolve_env_var("POSTGRES_URL")


# Compose service name of the metadata Postgres container. Stable in
# docker-compose.yml and unlikely to change without coordinated work
# elsewhere; hard-coded here so the daemon doesn't need to parse the
# compose file. Override via $SYNAPSE_POSTGRES_CONTAINER if you ever
# rename it, but doing so silently breaks the api side too.
POSTGRES_CONTAINER = os.environ.get("SYNAPSE_POSTGRES_CONTAINER", "synapse-postgres")


def _psql_exec(sql: str, params: list, log_path: Path) -> None:
    """Best-effort writeback via `docker exec synapse-postgres psql ...`.

    Why not host psql against the DSN: the DSN's hostname is `postgres`
    (the compose service name), only resolvable inside synapse-network.
    The daemon runs on the host as a systemd unit so it cannot resolve
    that name, and the postgres container's port binding may also be
    locked to 127.0.0.1. Furthermore, fresh Hetzner / Ubuntu hosts ship
    without psql on PATH. Going through `docker exec` avoids both
    problems — docker is already in the daemon's trust boundary
    (setup.sh --upgrade shells out to `docker compose` constantly).

    We still resolve the DSN to derive the postgres user/db (so a
    custom POSTGRES_USER / POSTGRES_DB in .env is honoured); falling
    back to the compose defaults if the DSN isn't parseable. Failures
    are logged to the per-job log file but don't crash the daemon —
    losing a row update is preferable to losing the run itself."""
    docker = shutil.which("docker")
    if not docker:
        return
    user, db = _parse_postgres_credentials()
    cmd = [
        docker, "exec", "-i", POSTGRES_CONTAINER,
        "psql", "-U", user, "-d", db, "-v", "ON_ERROR_STOP=1",
    ]
    # Use parameterised "$1, $2..." via -v-style is not supported; we
    # build the values via the env-and-format pattern. For safety with
    # untrusted input we shell-quote each param. Since we control all
    # callers, this is sufficient.
    quoted = []
    for p in params:
        if p is None:
            quoted.append("NULL")
        else:
            # psql accepts $$...$$ as a delimited literal; safer than
            # single-quoting ourselves because it sidesteps escape
            # concerns. We pick a unique tag to avoid collisions in
            # log payloads (which can contain $$).
            quoted.append("$tag$" + str(p) + "$tag$")
    rendered = sql
    for i, q in enumerate(quoted, start=1):
        rendered = rendered.replace(f"${i}", q)
    cmd.extend(["-c", rendered])
    try:
        subprocess.run(
            cmd, capture_output=True, text=True, timeout=10, check=False,
        )
    except (subprocess.SubprocessError, OSError) as e:
        try:
            with open(log_path, "ab") as logf:
                logf.write(f"\n[synapse-updater] psql writeback failed: {e}\n".encode())
        except OSError:
            pass


def _parse_postgres_credentials() -> tuple[str, str]:
    """Extract (user, db) from SYNAPSE_DB_URL, falling back to the
    POSTGRES_USER / POSTGRES_DB env entries, then to the compose
    defaults (synapse / synapse). Best-effort parse — a malformed DSN
    shouldn't take down the daemon."""
    user = _resolve_env_var("POSTGRES_USER")
    db = _resolve_env_var("POSTGRES_DB")
    if user and db:
        return user, db
    dsn = _resolve_postgres_dsn()
    if dsn:
        try:
            from urllib.parse import urlparse
            parsed = urlparse(dsn)
            if parsed.username and not user:
                user = parsed.username
            # path is "/dbname"; strip the leading slash.
            if parsed.path and len(parsed.path) > 1 and not db:
                db = parsed.path.lstrip("/")
        except Exception:  # noqa: BLE001 — parse failure -> defaults
            pass
    return user or "synapse", db or "synapse"


def run_reconfigure(job_id: str, payload: dict) -> None:
    """Worker thread for /reconfigure_host_domain. Writes admin_jobs
    state transitions via psql + captures stdout/stderr to a per-run
    log file. The api serves /v1/admin/host_domain/status/<id> by
    reading the same row, so we don't need to expose a daemon-side
    /status for this path."""
    started_at_iso = utc_now()
    log_path = LOG_DIR / f"reconfigure-{datetime.now(timezone.utc).strftime('%Y%m%dT%H%M%SZ')}.log"

    _psql_exec(
        "UPDATE admin_jobs SET state = 'running', started_at = now() WHERE id = $1",
        [job_id], log_path,
    )

    cmd = [str(INSTALL_DIR / "setup.sh"), "--reconfigure", "--non-interactive"]
    if payload.get("plainHttp"):
        cmd.append("--no-tls")
    else:
        if payload.get("domain"):
            cmd.append(f"--domain={payload['domain']}")
        if payload.get("baseDomain"):
            cmd.append(f"--base-domain={payload['baseDomain']}")
        if payload.get("acmeEmail"):
            cmd.append(f"--acme-email={payload['acmeEmail']}")

    child_env = dict(os.environ)
    child_env["SYNAPSE_UPDATER_NO_RESTART"] = "1"

    exit_code = 1
    try:
        with open(log_path, "wb") as logf:
            logf.write(
                f"[synapse-updater] starting: {' '.join(shlex.quote(c) for c in cmd)}\n".encode()
            )
            logf.flush()
            proc = subprocess.Popen(
                cmd,
                stdout=logf,
                stderr=subprocess.STDOUT,
                cwd=str(INSTALL_DIR),
                env=child_env,
            )
            exit_code = proc.wait()
    except (OSError, subprocess.SubprocessError) as e:
        try:
            with open(log_path, "ab") as logf:
                logf.write(f"\n[synapse-updater] spawn error: {e}\n".encode())
        except OSError:
            pass
        exit_code = 1

    final_state = "succeeded" if exit_code == 0 else "failed"
    log_excerpt = ""
    try:
        log_excerpt = log_path.read_text(errors="replace")
        # Cap the log we write back to the DB so a runaway setup.sh
        # doesn't bloat the row past comfortable JSON-payload sizes.
        if len(log_excerpt) > 64 * 1024:
            log_excerpt = "...\n" + log_excerpt[-64 * 1024:]
    except OSError:
        pass

    error_msg = ""
    if final_state == "failed":
        # Grab the last non-empty line as a one-line summary the
        # dashboard can render in a banner; full log stays in `log`.
        for line in reversed(log_excerpt.splitlines()):
            line = line.strip()
            if line:
                error_msg = line[:500]
                break
        if not error_msg:
            error_msg = f"setup.sh --reconfigure exited with code {exit_code}"

    _psql_exec(
        "UPDATE admin_jobs SET state = $1, finished_at = now(), log = $2, error = $3 WHERE id = $4",
        [final_state, log_excerpt, error_msg or None, job_id], log_path,
    )

    try:
        RECONFIGURE_LOCK_FILE.unlink()
    except FileNotFoundError:
        pass


class Handler(BaseHTTPRequestHandler):
    server_version = "synapse-updater/1.0"
    # Quiet the default access log — systemd journal already captures stderr.
    def log_message(self, *_args, **_kwargs):  # noqa: N802
        pass

    # The default address_string() expects (host, port) tuple. Unix-socket
    # peers come back as "" (or the abstract socket name) — short-circuit
    # to avoid IndexError logging.
    def address_string(self) -> str:
        return "unix"

    def _json(self, status: int, body: dict) -> None:
        payload = json.dumps(body).encode()
        self.send_response(status)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(payload)))
        self.send_header("Cache-Control", "no-store")
        self.end_headers()
        self.wfile.write(payload)

    def do_GET(self) -> None:  # noqa: N802
        if self.path == "/healthz":
            return self._json(200, {"ok": True})
        if self.path == "/version":
            return self._json(200, {"version": read_version()})
        if self.path == "/status":
            status = read_status()
            # If running, refresh the log tail at request time so the
            # dashboard sees streaming output without us having to push.
            if status.get("state") == "running":
                lp = status.get("logPath")
                if lp:
                    status["logTail"] = tail_log(Path(lp))
            return self._json(200, status)
        return self._json(404, {"error": "not_found"})

    def do_POST(self) -> None:  # noqa: N802
        if self.path == "/upgrade":
            return self._handle_upgrade()
        if self.path == "/reconfigure_host_domain":
            return self._handle_reconfigure()
        return self._json(404, {"error": "not_found"})

    def _read_body(self) -> tuple[dict, str]:
        length = int(self.headers.get("Content-Length", "0") or 0)
        if length <= 0:
            return {}, ""
        try:
            return json.loads(self.rfile.read(length).decode()), ""
        except (json.JSONDecodeError, UnicodeDecodeError):
            return {}, "invalid_json"

    def _handle_upgrade(self) -> None:
        body, err = self._read_body()
        if err:
            return self._json(400, {"error": err})

        ref = (body.get("ref") or "").strip()
        # ref must be a tag/branch — block shell metachars defensively.
        # setup.sh already validates, but a 400 here gives a clearer error
        # than waiting for setup.sh to refuse it.
        if ref and not all(c.isalnum() or c in "._-/+" for c in ref):
            return self._json(400, {"error": "invalid_ref"})

        # Single-flight: lock file is the source of truth so an old run
        # surviving a daemon restart still blocks new ones.
        if not upgrade_lock.acquire(blocking=False):
            return self._json(409, {"error": "upgrade_in_progress"})
        try:
            if LOCK_FILE.exists():
                return self._json(409, {"error": "upgrade_in_progress"})
            LOCK_FILE.write_text(f"{os.getpid()} {ref or 'latest'} {utc_now()}\n")
        finally:
            upgrade_lock.release()

        threading.Thread(target=run_upgrade, args=(ref,), daemon=True).start()
        return self._json(202, {"started": True, "ref": ref or "latest"})

    def _handle_reconfigure(self) -> None:
        body, err = self._read_body()
        if err:
            return self._json(400, {"error": err})

        job_id = (body.get("jobId") or "").strip()
        if not job_id:
            return self._json(400, {"error": "missing_job_id"})
        # jobId is a UUID written by the api — defensive sanity-check.
        if not all(c in "0123456789abcdef-" for c in job_id.lower()) or len(job_id) > 64:
            return self._json(400, {"error": "invalid_job_id"})

        # plainHttp + (domain | baseDomain) are mutually exclusive
        # — same rule the api enforces, mirrored here so a malformed
        # caller doesn't reach setup.sh with a contradictory flag set.
        plain = bool(body.get("plainHttp"))
        domain = (body.get("domain") or "").strip()
        base = (body.get("baseDomain") or "").strip()
        acme = (body.get("acmeEmail") or "").strip()
        if plain and (domain or base):
            return self._json(400, {"error": "invalid_payload"})
        if not plain and not domain and not base:
            return self._json(400, {"error": "invalid_payload"})

        # Block shell metacharacters in any forwarded value — setup.sh
        # quotes its own args but a hostname with backticks would
        # already fail validateDomain on the api side; this is
        # defense-in-depth against a future api regression.
        for v in (domain, base, acme):
            if v and any(c in v for c in " \t\n\r\\\"'`$;|&<>"):
                return self._json(400, {"error": "invalid_payload"})

        if not reconfigure_lock.acquire(blocking=False):
            return self._json(409, {"error": "reconfigure_in_progress"})
        try:
            if RECONFIGURE_LOCK_FILE.exists():
                return self._json(409, {"error": "reconfigure_in_progress"})
            RECONFIGURE_LOCK_FILE.write_text(f"{os.getpid()} {job_id} {utc_now()}\n")
        finally:
            reconfigure_lock.release()

        payload = {
            "domain": domain,
            "baseDomain": base,
            "plainHttp": plain,
            "acmeEmail": acme,
        }
        threading.Thread(target=run_reconfigure, args=(job_id, payload), daemon=True).start()
        return self._json(202, {"started": True, "jobId": job_id})


class ThreadingUnixHTTPServer(socketserver.ThreadingMixIn, socketserver.UnixStreamServer):
    """Unix-socket variant of HTTPServer. ThreadingMixIn lets a long /status
    poll not block a concurrent /upgrade. allow_reuse_address is meaningless
    for AF_UNIX, but daemon_threads ensures we exit cleanly on SIGTERM."""
    daemon_threads = True

    def server_bind(self) -> None:
        # Pre-clean any stale socket file from a crashed previous run.
        # systemd's Type=simple already restarts us, so this is the
        # defensive belt to socketserver's suspenders.
        try:
            os.unlink(self.server_address)
        except FileNotFoundError:
            pass
        super().server_bind()
        # 0660 + group=root means: only root can write; reading/writing
        # from a container requires the container to run as UID 0 inside
        # (which our synapse-api distroless static does).
        os.chmod(self.server_address, 0o660)


def main() -> int:
    sys.stderr.write(f"[synapse-updater] listening on unix:{SOCKET_PATH}\n")
    sys.stderr.flush()
    server = ThreadingUnixHTTPServer(str(SOCKET_PATH), Handler)
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        return 0
    finally:
        try:
            os.unlink(SOCKET_PATH)
        except FileNotFoundError:
            pass
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
