# Synapse — generated by setup.sh. Edit by hand only if you know why.
#
# This file is rendered by installer/install/secrets.sh on first
# install (the curly-brace tokens below are placeholder names that
# the renderer substitutes with values from exported env vars). On
# subsequent runs, existing values are preserved and new keys are
# appended (Coolify-style update_env_var).

# --- Server ---
SYNAPSE_HTTP_ADDR=0.0.0.0:8080
SYNAPSE_LOG_LEVEL=info

# --- Database ---
SYNAPSE_DB_URL=postgres://{{POSTGRES_USER}}:{{POSTGRES_PASSWORD}}@postgres:5432/{{POSTGRES_DB}}?sslmode=disable

# --- Auth ---
SYNAPSE_JWT_SECRET={{SYNAPSE_JWT_SECRET}}
SYNAPSE_JWT_ACCESS_TTL=15m
SYNAPSE_JWT_REFRESH_TTL=720h

# --- Provisioning ---
SYNAPSE_DOCKER_HOST=unix:///var/run/docker.sock
SYNAPSE_BACKEND_IMAGE=ghcr.io/get-convex/convex-backend:latest
SYNAPSE_DOCKER_NETWORK=synapse-network
SYNAPSE_PORT_RANGE_MIN=3210
SYNAPSE_PORT_RANGE_MAX=3500

# --- Reverse proxy ---
SYNAPSE_PROXY_ENABLED=true

# --- Public URL (REQUIRED for VPS / production) ---
# When set, /v1/deployments/{name}/cli_credentials returns a URL the
# remote operator can reach. Empty = local-dev (the legacy
# 127.0.0.1:port URL is what local CLIs need).
SYNAPSE_PUBLIC_URL={{SYNAPSE_PUBLIC_URL}}

# --- Custom domains (v1.0+, optional) ---
# When set, deployment URLs become "https://<name>.<BASE_DOMAIN>"
# instead of "<PublicURL>/d/<name>". Operator points wildcard DNS
# (*.<BASE_DOMAIN> A record -> VPS IP) and Caddy on-demand TLS
# issues per-host certs lazily.
# Empty disables the feature; the path-based proxy at /d/<name>/*
# keeps working unchanged.
SYNAPSE_BASE_DOMAIN={{SYNAPSE_BASE_DOMAIN}}

# --- CORS ---
# Restrict to the dashboard origin once you go behind TLS.
SYNAPSE_ALLOWED_ORIGINS={{SYNAPSE_ALLOWED_ORIGINS}}

# --- Healthcheck path (don't change unless you know why) ---
SYNAPSE_HEALTHCHECK_VIA_NETWORK=true

# --- HA (v0.5+, optional) ---
SYNAPSE_HA_ENABLED={{SYNAPSE_HA_ENABLED}}
SYNAPSE_STORAGE_KEY={{SYNAPSE_STORAGE_KEY}}
SYNAPSE_BACKEND_POSTGRES_URL=
SYNAPSE_BACKEND_S3_ENDPOINT=
SYNAPSE_BACKEND_S3_REGION=us-east-1
SYNAPSE_BACKEND_S3_ACCESS_KEY=
SYNAPSE_BACKEND_S3_SECRET_KEY=
SYNAPSE_BACKEND_S3_BUCKET_PREFIX=convex

# --- Aster runtime bridge (experimental, optional) ---
# Aster brokerd stays on the memory-store smoke path when these are empty.
# Set POSTGRES_URL to a Convex Postgres database and MODULES_DIR to the
# Docker-host path containing module bundle .blob files (the modules dir
# itself, not the storage root).
SYNAPSE_ASTER_POSTGRES_URL=
SYNAPSE_ASTER_DB_SCHEMA=public
SYNAPSE_ASTER_MODULES_DIR=

# --- Postgres (compose-only, seeds the metadata DB container) ---
POSTGRES_USER={{POSTGRES_USER}}
POSTGRES_PASSWORD={{POSTGRES_PASSWORD}}
POSTGRES_DB={{POSTGRES_DB}}
POSTGRES_PORT={{POSTGRES_PORT}}

# --- Compose host ports ---
SYNAPSE_PORT={{SYNAPSE_PORT}}
DASHBOARD_PORT={{DASHBOARD_PORT}}
CONVEX_DASHBOARD_PORT={{CONVEX_DASHBOARD_PORT}}
PUBLIC_SYNAPSE_URL={{SYNAPSE_PUBLIC_URL}}
PUBLIC_CONVEX_DASHBOARD_URL={{PUBLIC_CONVEX_DASHBOARD_URL}}
SYNAPSE_VERSION={{SYNAPSE_VERSION}}
