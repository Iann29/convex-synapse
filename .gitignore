dashboard/out/
dashboard/.env*.local
dashboard/.vercel
dashboard/dist/

# Env
.env
.env.local
*.env
!.env.example

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Docker volumes (when bind-mounted)
data/
volumes/
synapse/server
synapse/bin/

# Local-only test infrastructure (VPS credentials, SSH keys, scratch
# notes). Anything inside .vps/ is operator-private and MUST NOT be
# committed — it includes the synapse-test VPS root password +
# generated SSH keys.
/.vps/

# Caddyfile generated by setup.sh in compose mode (operator-rendered,
# not a fixture; bind-mounted into the caddy service)
/Caddyfile

# Local installer scratch (rendered .env, install logs)
/synapse-install.log
/install.log

# Playwright artefacts (root-level when running tests from CWD other than dashboard/)
test-results/

# Python bytecode caches (e.g. installer/updater/ daemon imports)
**/__pycache__/

# Claude Code runtime state (per-machine, not project)
.claude/scheduled_tasks.lock

# External-agent scratch space. The aster-runner-v0.2 prototype lives under
# docs/search/ so a parallel agent can keep iterating without polluting this
# repo's history. The validated copy is the standalone /home/ian/aster-runner
# repo (or its GitHub mirror).
docs/search/
