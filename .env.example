# Synapse config — copy to .env and edit before running

# --- Server ---
SYNAPSE_HTTP_ADDR=0.0.0.0:8080
SYNAPSE_LOG_LEVEL=info

# --- Database ---
SYNAPSE_DB_URL=postgres://synapse:synapse@postgres:5432/synapse?sslmode=disable

# --- Auth ---
# CHANGE THIS in production. Generate with: openssl rand -hex 64
SYNAPSE_JWT_SECRET=dev-only-change-me-please-aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
SYNAPSE_JWT_ACCESS_TTL=15m
SYNAPSE_JWT_REFRESH_TTL=720h

# --- Provisioning ---
# Docker socket path (Linux default)
SYNAPSE_DOCKER_HOST=unix:///var/run/docker.sock
# Image used for new deployments
SYNAPSE_BACKEND_IMAGE=ghcr.io/get-convex/convex-backend:latest
# Network the provisioned backends join
SYNAPSE_DOCKER_NETWORK=synapse-network
# Host-port range for exposed backends
SYNAPSE_PORT_RANGE_MIN=3210
SYNAPSE_PORT_RANGE_MAX=3500

# --- Reverse proxy (recommended for any non-localhost deployment) ---
# Mount /d/{name}/* on the same listener as the API so deployments share
# a single public host port. Without this, every Convex backend needs its
# own host port published in your firewall / ingress.
SYNAPSE_PROXY_ENABLED=true

# --- Public URL (REQUIRED for production / VPS) ---
# Externally-reachable origin of the Synapse instance — e.g. how a remote
# `npx convex` or a remote browser tab reaches Synapse. When set, the
# /v1/deployments/{name}/cli_credentials endpoint returns
# "<PublicURL>/d/<name>" (proxy mode) or "<PublicURL>:<port>" (host-port
# mode) instead of the container-internal "http://127.0.0.1:<port>" the
# provisioner stores. Leave empty for local dev (the legacy 127.0.0.1
# URL is what local CLIs need).
SYNAPSE_PUBLIC_URL=

# --- Custom domains (v1.1+, optional) ---
# IPv4 address operators publish in DNS for per-deployment custom
# domains. When set, POST /v1/deployments/{name}/domains synchronously
# resolves the supplied hostname and gates status='active' on a match.
# Empty (default) → DNS preflight is skipped; rows stay status='pending'
# with a "SYNAPSE_PUBLIC_IP not configured" hint. The proxy/TLS layer
# (PR #5) and dashboard UI (PR #6) consume the same rows.
SYNAPSE_PUBLIC_IP=

# --- HA (v0.5+, optional) ---
# Off by default. Turn on to allow create_deployment with `ha:true`. The
# control plane (Synapse) is multi-node-safe regardless; this flag is
# what enables active-passive replicas per *deployment*.
SYNAPSE_HA_ENABLED=false
# AES-256 key (hex-encoded, 64 chars) used to encrypt connection strings
# stored in deployment_storage. Generate with: openssl rand -hex 32
# Required when SYNAPSE_HA_ENABLED=true; harmless when it's false.
SYNAPSE_STORAGE_KEY=
# Cluster-wide defaults for HA-deployment storage. Each deployment gets
# its own database/schema and its own bucket prefix; these env vars are
# the starting point the operator can override per deployment.
SYNAPSE_BACKEND_POSTGRES_URL=
SYNAPSE_BACKEND_S3_ENDPOINT=
SYNAPSE_BACKEND_S3_REGION=us-east-1
SYNAPSE_BACKEND_S3_ACCESS_KEY=
SYNAPSE_BACKEND_S3_SECRET_KEY=
# Each deployment gets buckets named "<prefix>-<deployment>-files",
# "<prefix>-<deployment>-modules", etc. Operators are responsible for
# pre-creating the buckets (or pointing at a wildcard policy) — Synapse
# does not auto-create S3 buckets in v0.5.
SYNAPSE_BACKEND_S3_BUCKET_PREFIX=convex

# --- Postgres (used only by docker-compose to seed the postgres container) ---
POSTGRES_USER=synapse
POSTGRES_PASSWORD=synapse
POSTGRES_DB=synapse
POSTGRES_PORT=5432

# --- Compose-only ---
# Host ports
SYNAPSE_PORT=8080
DASHBOARD_PORT=6790
# Public URL the browser uses to reach Synapse (override if behind a proxy)
PUBLIC_SYNAPSE_URL=http://localhost:8080
# Image tag built by `docker compose build`
SYNAPSE_VERSION=dev
