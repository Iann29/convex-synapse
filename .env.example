# Synapse config — copy to .env and edit before running

# --- Server ---
SYNAPSE_HTTP_ADDR=0.0.0.0:8080
SYNAPSE_LOG_LEVEL=info

# --- Database ---
SYNAPSE_DB_URL=postgres://synapse:synapse@postgres:5432/synapse?sslmode=disable

# --- Auth ---
# CHANGE THIS in production. Generate with: openssl rand -hex 64
SYNAPSE_JWT_SECRET=dev-only-change-me-please-aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
SYNAPSE_JWT_ACCESS_TTL=15m
SYNAPSE_JWT_REFRESH_TTL=720h

# --- Provisioning ---
# Docker socket path (Linux default)
SYNAPSE_DOCKER_HOST=unix:///var/run/docker.sock
# Image used for new deployments
SYNAPSE_BACKEND_IMAGE=ghcr.io/get-convex/convex-backend:latest
# Network the provisioned backends join
SYNAPSE_DOCKER_NETWORK=synapse-network
# Host-port range for exposed backends
SYNAPSE_PORT_RANGE_MIN=3210
SYNAPSE_PORT_RANGE_MAX=3500

# --- Postgres (used only by docker-compose to seed the postgres container) ---
POSTGRES_USER=synapse
POSTGRES_PASSWORD=synapse
POSTGRES_DB=synapse
POSTGRES_PORT=5432

# --- Compose-only ---
# Host ports
SYNAPSE_PORT=8080
DASHBOARD_PORT=6790
# Public URL the browser uses to reach Synapse (override if behind a proxy)
PUBLIC_SYNAPSE_URL=http://localhost:8080
# Image tag built by `docker compose build`
SYNAPSE_VERSION=dev
